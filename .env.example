# =============================================================================
# REQUIRED: LLM Provider (choose one)
# =============================================================================
OPENROUTER_API_KEY=
# -- or --
ANTHROPIC_API_KEY=
# -- or --
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional: override default model (default: anthropic/claude-3.5-haiku)
LLM_MODEL=

# =============================================================================
# REQUIRED: Messaging Platform (choose at least one)
# =============================================================================

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=          # comma-separated user IDs
TELEGRAM_ALLOW_ALL_USERS=        # true to skip allowlist
TELEGRAM_HOME_CHANNEL=
TELEGRAM_HOME_CHANNEL_NAME=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=           # comma-separated user IDs
DISCORD_ALLOW_ALL_USERS=         # true to skip allowlist
DISCORD_HOME_CHANNEL=
DISCORD_HOME_CHANNEL_NAME=
DISCORD_REQUIRE_MENTION=
DISCORD_FREE_RESPONSE_CHANNELS=

# Slack (requires both tokens)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=             # comma-separated user IDs
SLACK_ALLOW_ALL_USERS=           # true to skip allowlist
SLACK_HOME_CHANNEL=
SLACK_HOME_CHANNEL_NAME=

# =============================================================================
# Radius Wallet (optional)
# =============================================================================
RADIUS_PRIVATE_KEY=              # auto-generated on first boot if not set
RADIUS_WALLET_ADDRESS=           # auto-generated on first boot if not set
RADIUS_NETWORK=                  # defaults to Radius Testnet
RADIUS_AUTO_FUND=                # true to auto-request faucet funds on boot

# =============================================================================
# Linear (optional)
# =============================================================================
LINEAR_API_KEY=              # Personal API key from Linear Settings → API → Personal API keys
LINEAR_TEAM_ID=              # Default team ID to scope issue operations (optional)
LINEAR_PROJECT_ID=           # Specific project ID to interact with (optional)

# =============================================================================
# Persistent Storage (optional)
# =============================================================================

BYTEROVER_API_KEY=           # Cloud sync mode — set to use ByteRover cloud account
BYTEROVER_LOCAL=             # true to use ByteRover in local-only mode (no API key needed)




# =============================================================================
# Tool Integrations (optional)
# =============================================================================
FIRECRAWL_API_KEY=
GITHUB_TOKEN=
FAL_KEY=
ELEVENLABS_API_KEY=
VOICE_TOOLS_OPENAI_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_PROXIES=
BROWSERBASE_ADVANCED_STEALTH=
NOUS_API_KEY=
TINKER_API_KEY=
WANDB_API_KEY=
RL_API_URL=

# =============================================================================
# Terminal Backend (optional)
# =============================================================================
TERMINAL_BACKEND=                # local, docker, singularity, modal, ssh
TERMINAL_CWD=
TERMINAL_TIMEOUT=
TERMINAL_LIFETIME_SECONDS=
TERMINAL_DOCKER_IMAGE=
TERMINAL_SINGULARITY_IMAGE=
TERMINAL_MODAL_IMAGE=
TERMINAL_CONTAINER_CPU=
TERMINAL_CONTAINER_MEMORY=
TERMINAL_CONTAINER_DISK=
TERMINAL_CONTAINER_PERSISTENT=
TERMINAL_SANDBOX_DIR=
TERMINAL_SSH_HOST=
TERMINAL_SSH_USER=
TERMINAL_SSH_PORT=
TERMINAL_SSH_KEY=
SUDO_PASSWORD=

# =============================================================================
# Hermes Tuning (optional)
# =============================================================================
HERMES_INFERENCE_PROVIDER=
HERMES_PORTAL_BASE_URL=
NOUS_INFERENCE_BASE_URL=
HERMES_NOUS_MIN_KEY_TTL_SECONDS=
HERMES_MAX_ITERATIONS=
HERMES_TOOL_PROGRESS=
HERMES_TOOL_PROGRESS_MODE=
HERMES_DUMP_REQUESTS=
CONTEXT_COMPRESSION_ENABLED=
CONTEXT_COMPRESSION_THRESHOLD=
CONTEXT_COMPRESSION_MODEL=

# =============================================================================
# Gateway (optional)
# =============================================================================
GATEWAY_ALLOW_ALL_USERS=         # true to allow all users across all platforms
WHATSAPP_ENABLED=
WHATSAPP_ALLOWED_USERS=

# =============================================================================
# Agent Identity (optional)
# =============================================================================
AGENT_DESCRIPTION=       # One-line description published in /.well-known/agent-card.json

# =============================================================================
# Webhook / A2A Bridge (optional)
# =============================================================================
# Enable Hermes webhook server so POST /a2a can forward tasks to it.
WEBHOOK_ENABLED=         # true to enable
WEBHOOK_PORT=            # default: 8644
WEBHOOK_SECRET=          # Required for A2A bridge — HMAC key for Hermes webhook auth

# =============================================================================
# JWT Gate (optional)
# =============================================================================
# API key used to exchange for a JWT via POST /token with X-Api-Key header.
# Leave unset to disable token issuance endpoint.
# JWT signing reuses RADIUS_PRIVATE_KEY (secp256k1, shared with the wallet).
JWT_API_KEY=
# Comma-separated DID allowlist for inbound A2A JWT auth.
# When set, only these DIDs (plus this agent's own DID) can call gated endpoints.
# Leave unset to accept any cryptographically valid DID JWT.
TRUSTED_DIDS=

# =============================================================================
# Debug (optional)
# =============================================================================
WEB_TOOLS_DEBUG=
VISION_TOOLS_DEBUG=
MOA_TOOLS_DEBUG=
IMAGE_TOOLS_DEBUG=
