# =============================================================================
# REQUIRED: LLM Provider (choose one)
# =============================================================================
OPENROUTER_API_KEY=
# -- or --
ANTHROPIC_API_KEY=
# -- or --
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional: override default model (default: anthropic/claude-3.5-haiku)
LLM_MODEL=

# =============================================================================
# REQUIRED: Messaging Platform (choose at least one)
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# =============================================================================
# Radius Wallet Registry
# =============================================================================
RADIUS_WALLETS=local
RADIUS_DEFAULT_WALLET=local
RADIUS_NETWORK=testnet
RADIUS_AUTO_FUND_ON_BOOT=true
RADIUS_AUTO_FUND_WALLETS=local
RADIUS_WALLET_MANIFEST=

# Local wallet
RADIUS_LOCAL_PRIVATE_KEY=
RADIUS_LOCAL_AUTO_GENERATE=true

# Para wallet
PARA_API_KEY=
PARA_ENVIRONMENT=beta
PARA_WALLET_IDENTIFIER=
PARA_WALLET_IDENTIFIER_TYPE=CUSTOM_ID
PARA_AUTO_CREATE=true
PARA_USER_SHARE=

# Legacy (backward compatibility)
RADIUS_PRIVATE_KEY=
RADIUS_WALLET_ADDRESS=
RADIUS_AUTO_FUND=

# Optional integrations
GITHUB_TOKEN=
FIRECRAWL_API_KEY=
